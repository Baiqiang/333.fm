{
  "name": "333.fm-monorepo",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev:frontend": "pnpm --filter 333.fm dev",
    "dev:server": "pnpm --filter 333.fm-server start:dev",
    "build": "pnpm -r build",
    "build:frontend": "pnpm --filter 333.fm build",
    "build:server": "pnpm --filter 333.fm-server build",
    "lint": "pnpm -r lint",
    "lint:frontend": "pnpm --filter 333.fm lint",
    "lint:server": "pnpm --filter 333.fm-server lint"
  }
}
